# ==================== AWS Marketplace Runtime ====================
# AWS Marketplace API 固定区域
MARKETPLACE_REGION=us-east-1

# CostQ Marketplace Product
MARKETPLACE_PRODUCT_CODE=2p87p8znttoi3byyvne3pr3jb
MARKETPLACE_SELLER_ACCOUNT_ID=642157749042

# Marketplace 订阅后重定向到前端 onboarding 页面
MARKETPLACE_FULFILLMENT_RETURN_URL=https://agent.costq.jp/marketplace/onboarding

# AWS Marketplace SNS Topics
MARKETPLACE_SUBSCRIPTION_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:287250355862:aws-mp-subscription-notification-2p87p8znttoi3byyvne3pr3jb
MARKETPLACE_ENTITLEMENT_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:287250355862:aws-mp-entitlement-notification-2p87p8znttoi3byyvne3pr3jb

# Marketplace onboarding token expiry
MARKETPLACE_ONBOARDING_TOKEN_EXPIRE_MINUTES=120

# Local / test only. Production should normally be false.
MARKETPLACE_ENABLE_TEST_MODE=false

# CloudFormation-first mode:
# - Keep web SNS handler OFF when SNS is consumed by CFN stack.
# - Keep web metering API OFF when metering is executed by CFN Lambda pipeline.
MARKETPLACE_ENABLE_WEB_SNS_HANDLER=false
MARKETPLACE_ENABLE_WEB_METERING_API=false

# ==================== Ops Reference Only ====================
# 这些值当前代码不直接依赖，但建议保留在部署文档中用于排查
MARKETPLACE_PRODUCT_ID=prod-ssodbgfe4cgma
MARKETPLACE_PRODUCT_ARN=arn:aws:aws-marketplace:us-east-1:642157749042:AWSMarketplace/SaaSProduct/prod-ssodbgfe4cgma

# ==================== Related Endpoint Reference ====================
# Marketplace Fulfillment URL 应在 AWS Marketplace 控制台配置为：
# https://agent.costq.jp/api/marketplace/fulfillment
#
# SNS HTTPS endpoint 应订阅到：
# https://agent.costq.jp/api/marketplace/sns
